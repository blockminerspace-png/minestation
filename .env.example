# Copie para `.env` na raiz do repositório (opcional: o compose também lê `.env` para POSTGRES_PASSWORD).
# Não commite `.env` com segredos reais.
#
# O compose publica 3000:3000 — a porta 3000 no host precisa estar livre antes de `docker compose up`.

# Senha do PostgreSQL (deve ser a mesma em DATABASE_URL abaixo, se você sobrescrever DATABASE_URL).
POSTGRES_PASSWORD=postgres

# --- Backend em runtime (carregados no container se estiverem no `.env`) ---
# Se não definir, o compose usa o Postgres interno (`db`). Para banco externo, defina aqui.
# DATABASE_URL=postgres://usuario:senha@host:5432/minestation

PORT=3000
NODE_ENV=production
FRONTEND_URL=http://localhost:3000
JWT_SECRET=
API_KEY=
POLYGON_RPC=https://polygon-rpc.com
BNB_RPC=
BASE_RPC=

# --- Build local do frontend (fora do Docker) ---
# API_PORT=3001
# VITE_API_URL=http://localhost:3001/api

# Imagem Docker usa o diretório `frontend/dist` já existente. Para atualizar o bundle,
# rode `npm run build` em `frontend/` no host antes de `docker compose build`.
