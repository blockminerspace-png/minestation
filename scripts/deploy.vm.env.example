# Copiar para `scripts/deploy.vm.env` (ficheiro ignorado pelo git) e preencher.
# O `scripts/vm-maintenance.sh` e `scripts/deploy-vm.sh` carregam-no por cima do `.env` da raiz.

SSH_HOST=177.7.47.139
SSH_USER=root
SSH_PORT=2222
# Palavra-passe SSH (opcional): com `sshpass` instalado, ou com `python3` + módulo `pexpect` (scripts/ssh_pexpect.py).
# SSH_PASSWORD=

# Pasta com docker-compose.yml do stack em produção
REMOTE_REPO_DIR=/root/minestation/app_production
# Raiz do clone git (onde existe .git). Se comentar, o vm-maintenance deduz o pai de app_production.
# REMOTE_GIT_DIR=/root/minestation

PG_CONTAINER=postgres_app
PG_DATABASE=minestation
APP_SERVICE=app
