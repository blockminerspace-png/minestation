{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": false,
    "noImplicitAny": false,
    "useUnknownInCatchVariables": false,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "noEmitOnError": true,
    "outDir": ".",
    "rootDir": "."
  },
  "include": ["server.ts", "types/**/*.d.ts"],
  "exclude": ["node_modules", "dist", "frontend", "assets"]
}
