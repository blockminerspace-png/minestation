{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "outDir": "./dist",
    "rootDir": ".",
    "skipLibCheck": true,
    "noEmitOnError": true,
    "esModuleInterop": true
  },
  "include": ["cron/**/*.ts", "lib/safeText.ts"],
  "exclude": ["node_modules", "dist"]
}
