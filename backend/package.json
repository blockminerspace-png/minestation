{
  "name": "genesis-miner-backend",
  "version": "1.3.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "npx prisma generate && npm run build:server && node server.js",
    "build:cron": "tsc -p tsconfig.cron.json",
    "build:ts": "tsc -p tsconfig.json",
    "build:server": "npm run build:ts && tsc -p tsconfig.server.json",
    "build:app": "npx prisma generate && rm -rf dist/cron 2>/dev/null && npm run build:cron && npm run build:server && mkdir -p dist/lib && cp lib/miningLivePrices.js dist/lib/miningLivePrices.js",
    "prestart": "npm run build:app",
    "start": "node server.js",
    "test": "node ./node_modules/vitest/vitest.mjs run",
    "test:watch": "node ./node_modules/vitest/vitest.mjs",
    "test:cov": "node ./node_modules/vitest/vitest.mjs run --coverage",
    "img:classify": "npm run build:ts && node scripts/run-img-organize.mjs",
    "assets:compress": "npm run build:server && node scripts/compress-site-assets.mjs",
    "img:rewrite-db": "node scripts/rewrite-img-paths-after-reorg.mjs",
    "img:repair-rack-infra": "node scripts/repair-infra-rack-images.mjs",
    "sanitize:legacy-stock": "node scripts/sanitize_legacy_stock_items.mjs",
    "db:remove-legacy-items": "node scripts/remove_legacy_catalog_items.mjs",
    "db:remove-legacy-items:apply": "node scripts/remove_legacy_catalog_items.mjs --apply",
    "db:cleanup-corrupted-player-items": "node scripts/cleanup_corrupted_player_items.mjs",
    "db:cleanup-corrupted-player-items:apply": "node scripts/cleanup_corrupted_player_items.mjs --apply",
    "db:ensure-stored-batteries": "npm run build:ts && node scripts/ensure_stored_batteries_integrity.mjs",
    "db:ensure-stored-batteries:docker": "docker exec -i ${PG_CONTAINER:-app-postgres} psql -U postgres -d ${PG_DATABASE:-minestation} -v ON_ERROR_STOP=1 < scripts/ensure_stored_batteries_integrity.sql",
    "db:normalize-public-assets": "npm run build:ts && node scripts/normalize-db-public-asset-urls.mjs",
    "db:audit-batteries-email": "npm run build:ts && node scripts/audit-batteries-by-email.mjs",
    "battery:diagnostic": "node scripts/battery_diagnostic_readonly.mjs",
    "battery:repair:dry": "node scripts/battery_repair_dryrun.mjs",
    "battery:repair:apply": "npm run build:ts && node scripts/battery_repair_dryrun.mjs --apply",
    "battery:full-to-stock": "node scripts/convert_full_stored_batteries_to_stock.mjs",
    "battery:full-to-stock:apply": "node scripts/convert_full_stored_batteries_to_stock.mjs --apply",
    "battery:1000-to-protostar": "node scripts/convert_1000wh_batteries_to_protostar.mjs",
    "battery:1000-to-protostar:apply": "node scripts/convert_1000wh_batteries_to_protostar.mjs --apply",
    "db:pull": "node scripts/runPrismaWithEnv.mjs db pull",
    "schema:validate": "npx prisma validate",
    "migrate:deploy": "node scripts/runPrismaWithEnv.mjs migrate deploy",
    "migrate:dev": "node scripts/runPrismaWithEnv.mjs migrate dev",
    "migrate:status": "node scripts/runPrismaWithEnv.mjs migrate status"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@google/genai": "*",
    "@prisma/client": "^6.19.0",
    "@socket.io/redis-adapter": "^8.3.0",
    "bcryptjs": "*",
    "bullmq": "^5.63.0",
    "cors": "*",
    "ethers": "^6.15.0",
    "dotenv": "*",
    "express": "*",
    "express-rate-limit": "*",
    "helmet": "*",
    "ioredis": "^5.8.2",
    "jsonwebtoken": "^9.0.3",
    "mongodb": "^6.21.0",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.5",
    "pg": "^8.20.0",
    "prisma": "^6.19.0",
    "sharp": "^0.34.5",
    "socket.io": "^4.8.1",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.25",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^1.4.13",
    "@types/node": "^20.19.39",
    "@types/nodemailer": "^6.4.23",
    "@types/pg": "^8.20.0",
    "@vitest/coverage-v8": "^4.1.5",
    "typescript": "^5.3.3",
    "vitest": "^4.1.5"
  }
}
