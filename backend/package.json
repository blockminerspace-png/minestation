{
  "name": "genesis-miner-backend",
  "version": "1.3.0",
  "private": true,
  "type": "module",
  "scripts": {
    "prepare": "npm run build:server",
    "dev": "prisma generate && npm run build:server && node server.js",
    "build:cron": "tsc -p tsconfig.cron.json",
    "build:ts": "tsc -p tsconfig.json",
    "build:server": "npm run build:ts && npm run build:cron && tsc -p tsconfig.server.json",
    "build:app": "prisma generate && rm -rf dist/cron 2>/dev/null && npm run build:cron && npm run build:server && mkdir -p dist/lib && cp lib/miningLivePrices.js dist/lib/miningLivePrices.js",
    "prestart": "npm run build:app",
    "start": "node server.js",
    "test": "node ./node_modules/vitest/vitest.mjs run",
    "test:watch": "node ./node_modules/vitest/vitest.mjs",
    "test:cov": "node ./node_modules/vitest/vitest.mjs run --coverage",
    "img:classify": "npm run build:ts && node scripts/run-img-organize.mjs",
    "assets:compress": "npm run build:server && node scripts/compress-site-assets.mjs",
    "img:rewrite-db": "node scripts/rewrite-img-paths-after-reorg.mjs",
    "sanitize:legacy-stock": "node scripts/sanitize_legacy_stock_items.mjs",
    "db:pull": "prisma db pull",
    "schema:validate": "prisma validate",
    "migrate:deploy": "prisma migrate deploy",
    "migrate:dev": "prisma migrate dev",
    "migrate:status": "prisma migrate status"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@google/genai": "*",
    "@prisma/client": "^6.19.0",
    "@socket.io/redis-adapter": "^8.3.0",
    "bcryptjs": "*",
    "bullmq": "^5.63.0",
    "cors": "*",
    "dotenv": "*",
    "ethers": "^6.15.0",
    "express": "*",
    "express-rate-limit": "*",
    "helmet": "*",
    "ioredis": "^5.8.2",
    "jsonwebtoken": "^9.0.3",
    "mongodb": "^6.21.0",
    "multer": "^2.0.2",
    "nodemailer": "^8.0.7",
    "pg": "^8.20.0",
    "sharp": "^0.34.5",
    "socket.io": "^4.8.1",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.25",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^1.4.13",
    "@types/node": "^20.19.39",
    "@types/nodemailer": "^8.0.0",
    "@types/pg": "^8.20.0",
    "@vitest/coverage-v8": "^2.1.9",
    "prisma": "^7.8.0",
    "typescript": "^5.3.3",
    "vitest": "^2.1.9"
  },
  "overrides": {
    "esbuild": "^0.25.0",
    "vite": "^6.4.2"
  }
}
