{
  "name": "genesis-miner-backend",
  "version": "1.3.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build:cron": "tsc -p tsconfig.cron.json",
    "build:ts": "tsc -p tsconfig.json",
    "build:server": "tsc -p tsconfig.server.json",
    "build:app": "rm -rf dist/cron 2>/dev/null; npm run build:cron && npm run build:ts && npm run build:server",
    "prestart": "npm run build:app",
    "start": "node server.js",
    "test": "node ./node_modules/vitest/vitest.mjs run",
    "test:watch": "node ./node_modules/vitest/vitest.mjs",
    "test:cov": "node ./node_modules/vitest/vitest.mjs run --coverage",
    "img:classify": "npm run build:ts && node scripts/run-img-organize.mjs",
    "img:rewrite-db": "node scripts/rewrite-img-paths-after-reorg.mjs",
    "sanitize:legacy-stock": "node scripts/sanitize_legacy_stock_items.mjs"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@google/genai": "*",
    "bcryptjs": "*",
    "cors": "*",
    "dotenv": "*",
    "express": "*",
    "express-rate-limit": "*",
    "helmet": "*",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.0.2",
    "nodemailer": "^6.9.0",
    "pg": "^8.20.0",
    "sharp": "^0.34.5",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.25",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^1.4.13",
    "@types/node": "^20.19.39",
    "@types/nodemailer": "^6.4.23",
    "@types/pg": "^8.20.0",
    "@vitest/coverage-v8": "^2.1.9",
    "typescript": "^5.3.3",
    "vitest": "^2.1.9"
  }
}
