{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "outDir": "./dist",
    "rootDir": ".",
    "skipLibCheck": true,
    "esModuleInterop": true,
    "declaration": false,
    "noEmitOnError": true
  },
  "include": [
    "config/**/*.ts",
    "controllers/**/*.ts",
    "models/**/*.ts",
    "validation/**/*.ts",
    "src/auth/**/*.ts",
    "lib/**/*.ts",
    "utils/**/*.ts",
    "types/**/*.d.ts"
  ],
  "exclude": ["node_modules", "dist"]
}
