{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "outDir": "./dist",
    "rootDir": ".",
    "skipLibCheck": true,
    "esModuleInterop": true,
    "declaration": false,
    "noEmitOnError": true
  },
  "include": ["controllers/**/*.ts", "models/**/*.ts", "types/**/*.d.ts"],
  "exclude": ["node_modules", "dist"]
}
