# Dependencies
node_modules/
backend/node_modules/
frontend/node_modules/
admin/node_modules/

# Build output
frontend/dist/

# Coverage (Vitest)
backend/coverage/
frontend/coverage/

# Backend — artefactos gerados (não versionar)
backend/dist/
backend/assets/
# Cópia obsoleta de ficheiros do frontend; fonte única: pasta `frontend/` na raiz
backend/frontend/

# Deploy VM (credenciais — nunca commitar)
scripts/deploy.vm.env

# Let's Encrypt na VM (chaves / material ACME — nunca versionar)
app_production/certbot/conf/archive/
app_production/certbot/conf/live/
app_production/certbot/conf/renewal/

# Snapshot legado de deploy — chaves TLS / conta ACME (nunca versionar)
deployment_legacy_20260506/**/privkey*.pem
deployment_legacy_20260506/**/private_key.json

# Environment files (segredos — NUNCA versionar)
.env
backend/.env
admin/.env
frontend/.env
# Backups de .env contêm segredos em claro
.env.bak*
**/.env.bak*
.env.backup*
**/.env.backup*

# Database backups (sensitive data)
backups/
*.sql
# Prisma migrations must be versioned
!backend/prisma/migrations/**/*.sql
# Manutenção idempotente — corre no vm-maintenance.sh
!backend/scripts/*.sql
*.rar
*.zip

# Docker volumes
pgdata/

# OS files
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/

# Logs
*.log
npm-debug.log*

# Temp scripts
tmp_*.js
backend/tmp_*.js

# Obsidian and Documentation
Obsidian_Docs/
scratch/
DOCUMENTACAO.md
README.md
