# Stack Docker em deployment/docker-compose.yml: PostgreSQL + MongoDB (logs) + Redis (filas/socket).
# O compose define REDIS_URL e MONGODB_URI no serviço `app`; não uses um compose antigo só com db+app+nginx.
#
# Segredos só neste ficheiro (ou secrets do CI) — nunca em código. Mongo: ver backend/docs/MONGO_LOG_CONTRACT.md
# REDIS_URL=redis://redis:6379
# MONGODB_URI=mongodb://mongo:27017/genesis_logs
# GENESIS_MONGO_DB=genesis_logs
PORT=3000
DATABASE_URL=postgres://postgres:SuaSenhaSeguraAqui@db:5432/minestation
POSTGRES_PASSWORD=SuaSenhaSeguraAqui
NODE_ENV=production
POLYGON_RPC=https://polygon-bor-rpc.publicnode.com
# Opcional — carga DB (throttle por worker; ver .env.example na raiz).
# ACTIVITY_LAST_ACTIVE_MIN_MS=30000
# ACTIVITY_HISTORY_IP_MIN_MS=60000
# ACTIVITY_THROTTLE_MAP_MAX=100000
# UPGRADES_SNAPSHOT_CACHE_TTL_MS=60000
# Obrigatório para CORS e links nos emails: URL exata do browser (sem barra final).
FRONTEND_URL=https://test.genesisdao.tech
# Opcional: mais origens (dev, staging), separadas por vírgula.
# CORS_ALLOWED_ORIGINS=https://staging.test.genesisdao.tech
# API_KEY=...
